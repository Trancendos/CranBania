# CranBania — Docker build exclusions
# Keep the image lean: exclude dev artifacts, local data, CI configs

# node artifacts
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Next.js build output (rebuilt in container)
.next
out

# local dev data
data/*.db
data/*.json
*.sqlite
*.sqlite3

# environment files (injected at runtime)
.env
.env.*
!.env.example

# test & lint
__tests__
*.test.ts
*.spec.ts
coverage/
.nyc_output/

# CI / version control
.git
.gitignore
.gitmodules
.woodpecker/
.github/
.cursor/

# docs (not needed at runtime)
docs/
*.md
STRATEGY.md
AGENTS.md

# editor
.vscode/
.idea/
*.swp
*.swo
